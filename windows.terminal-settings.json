{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": 
    [
        {
            "command": 
            {
                "action": "copy",
                "singleLine": false
            },
            "keys": "ctrl+c"
        },
        {
            "command": "paste",
            "keys": "ctrl+v"
        },
        {
            "command": 
            {
                "action": "splitPane",
                "split": "auto",
                "splitMode": "duplicate"
            },
            "keys": "alt+shift+d"
        },
        {
            "command": "find",
            "keys": "ctrl+shift+f"
        }
    ],
    "copyFormatting": "none",
    "copyOnSelect": false,
    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "newTabMenu": 
    [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles": 
    {
        "defaults": {
		    "colorScheme": "rose-pine",
            "cursorShape": "vintage",
		    "font": {
    			"face": "FiraCode Nerd Font",
    			"size": 18,
    			"weight": "normal"
		    },
		    "opacity": 70,
		"   useAcrylic": false
	    },
        "list": 
        [
            {
                "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "hidden": false,
                "name": "Windows PowerShell"
            },
            {
                "commandline": "%SystemRoot%\\System32\\cmd.exe",
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "hidden": false,
                "name": "Command Prompt"
            },
            {
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "hidden": false,
                "name": "PowerShell",
                "source": "Windows.Terminal.PowershellCore"
            },
        ]
    },
    "schemes": 
    [
        {
  	    "name": "rose-pine",

  	    "cursorColor": "#555169",
  	    "selectionBackground": "#2a2837",

  	    "background": "#191724",
  	    "foreground": "#e0def4",

  	    "black": "#26233a",
  	    "blue": "#9ccfd8",
  	    "cyan": "#ebbcba",
  	    "green": "#31748f",
  	    "purple": "#c4a7e7",
  	    "red": "#eb6f92",
  	    "white": "#e0def4",
  	    "yellow": "#f6c177",
  	    "brightBlack": "#6e6a86",
  	    "brightBlue": "#9ccfd8",
  	    "brightCyan": "#ebbcba",
  	    "brightGreen": "#31748f",
  	    "brightPurple": "#c4a7e7",
  	    "brightRed": "#eb6f92",
  	    "brightWhite": "#e0def4",
  	    "brightYellow": "#f6c177"
	    }	
    ],
    "themes": [
	{
  	    "name": "rose-pine",
  	    "tab": {
    		"background": "#191724FF",
    		"showCloseButton": "always",
    		"unfocusedBackground": null
  	    },
  	    "tabRow": {
    		"background": "#26233AFF",
